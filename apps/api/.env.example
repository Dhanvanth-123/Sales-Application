# ── Core ──
# Host ports are offset from the defaults (API 4100, Postgres 5433, MinIO 9100,
# Redis 6380) so CALIPER coexists with other local stacks — see docker-compose.yml.
NODE_ENV=development
PORT=4100
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://caliper:caliper@localhost:5433/caliper?schema=public

# ── Auth (Option A: self-managed JWT, RS256) ──
# Either inline the PEM (escape newlines as \n) …
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# … or point to PEM files (preferred for local dev; generated into ./secrets):
JWT_PRIVATE_KEY_PATH=./secrets/jwt.private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt.public.pem
JWT_ACCESS_TTL=15m
JWT_ISSUER=caliper
JWT_AUDIENCE=caliper-web
REFRESH_TOKEN_SECRET=CHANGE_ME_64_BYTE_HEX
REFRESH_TOKEN_TTL=30d

# ── Auth (Option B: Entra ID / Azure AD) — fill if using SSO (Phase 6) ──
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Object storage (S3 / R2 / MinIO) — Phase 6 ──
S3_ENDPOINT=http://localhost:9100
S3_REGION=ap-south-1
S3_BUCKET=caliper-attachments
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Email — Phase 6 ──
SENDGRID_API_KEY=
MAIL_FROM="CALIPER <noreply@yourcompany.com>"

# ── Cache / queue / monitoring — optional ──
REDIS_URL=redis://localhost:6380
SENTRY_DSN=

# ── Optional: assisted PVC commodity feed ──
METALS_API_KEY=
